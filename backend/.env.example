# Django
DJANGO_SECRET_KEY=change-this-to-a-long-random-secret-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://lunch_user:lunch_pass@localhost:5432/office_lunch_db

# Timezone
TIME_ZONE=Asia/Kolkata

# JWT
ACCESS_TOKEN_LIFETIME_MIN=30
REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS - frontend origin(s), comma separated
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Business rules
COMPANY_UPI_ID=officecanteen@upi
ORDER_CUTOFF_HOUR=11
